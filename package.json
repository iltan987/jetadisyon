{
  "name": "jetadisyon",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "check-types": "turbo run check-types",
    "clean": "turbo run clean && rm -rf .turbo",
    "test": "turbo run test",
    "dev:infra": "docker compose up -d",
    "dev:infra:stop": "docker compose down",
    "prepare": "husky"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "turbo": "^2.9.6"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "@types/node": "^25.6.0",
      "typescript": "^5.9.3",
      "eslint": "^9.39.4"
    },
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/engines",
      "esbuild",
      "msw",
      "prisma",
      "unrs-resolver"
    ]
  }
}
