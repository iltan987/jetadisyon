# PostgreSQL connection string — do not commit the real value
DATABASE_URL=postgres://postgres:postgres@localhost:5432/jetadisyon

# HTTP port the API listens on (default: 3000)
PORT=3000

# Runtime environment: development | production | test (default: development)
NODE_ENV=development

# Comma-separated list of allowed CORS origins (no trailing slashes)
CORS_ORIGIN=http://localhost:5173,http://localhost:1420
